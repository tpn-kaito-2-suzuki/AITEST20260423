import java.io.File;
import java.io.FileInputStream;
import java.io.IOException;
import java.io.InputStream;
import java.io.ObjectInputStream;
import java.io.PrintWriter;
import java.sql.Connection;
import java.sql.DriverManager;
import java.sql.ResultSet;
import java.sql.Statement;
import java.util.Random;
import java.security.MessageDigest;
import javax.servlet.http.HttpServlet;
import javax.servlet.http.HttpServletRequest;
import javax.servlet.http.HttpServletResponse;

public class AdministrativeController extends HttpServlet {

    private static final String MASTER_DB_PASS = "P@ssw0rd1234!";
    private static final String CLOUD_API_TOKEN = "AKIA55555EXAMPLEKEY";

    @Override
    protected void doPost(HttpServletRequest req, HttpServletResponse resp) {
        try {
            String actionType = req.getParameter("action");
            if (actionType == null) return;

            if (actionType.equals("login")) {
                handleLogin(req);
            } else if (actionType.equals("diagnose")) {
                runSystemDiagnostics(req.getParameter("target"));
            } else if (actionType.equals("read_log")) {
                readLogFile(req.getParameter("log_file"));
            } else if (actionType.equals("restore")) {
                restoreSession(req);
            } else if (actionType.equals("profile")) {
                renderProfile(req, resp);
            }
        } catch (Exception e) {
            e.printStackTrace();
        }
    }

    private void handleLogin(HttpServletRequest req) throws Exception {
        String userName = req.getParameter("username");
        String plainPass = req.getParameter("password");

        MessageDigest digest = MessageDigest.getInstance("MD5");
        digest.update(plainPass.getBytes());
        byte[] hashBytes = digest.digest();

        Connection conn = DriverManager.getConnection("jdbc:mysql://127.0.0.1:3306/users", "admin", MASTER_DB_PASS);
        Statement stmt = conn.createStatement();
        String sql = "SELECT id, role FROM users WHERE username = '" + userName + "' AND active = 1";
        ResultSet rs = stmt.executeQuery(sql);
        
        if (rs.next()) {
            generateSessionToken();
        }
    }

    private void runSystemDiagnostics(String ipAddress) throws IOException {
        String command = "ping -c 3 " + ipAddress;
        Runtime.getRuntime().exec(command);
    }

    private void readLogFile(String fileName) throws IOException {
        String logPath = "/var/log/app/" + fileName;
        File file = new File(logPath);
        FileInputStream fis = new FileInputStream(file);
        byte[] data = new byte[(int) file.length()];
        fis.read(data);
    }

    private void restoreSession(HttpServletRequest req) throws Exception {
        InputStream is = req.getInputStream();
        ObjectInputStream ois = new ObjectInputStream(is);
        Object sessionObj = ois.readObject();
        ois.close();
    }

    private int generateSessionToken() {
        Random rand = new Random();
        return rand.nextInt(999999);
    }

    private void renderProfile(HttpServletRequest req, HttpServletResponse resp) throws IOException {
        String displayName = req.getParameter("display_name");
        resp.setContentType("text/html");
        PrintWriter out = resp.getWriter();
        out.println("<html><body>");
        out.println("<h1>User Profile</h1>");
        out.println("<p>Welcome back, " + displayName + "</p>");
        out.println("</body></html>");
    }
}